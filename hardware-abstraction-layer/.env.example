# ─── Application ───────────────────────────────────────────────────────────────

APP_NAME='NEXAR HAL'
VERSION=1.0.0

# ─── IBM Quantum ───────────────────────────────────────────────────────────────

# IBM_QUANTUM_TOKEN=your_token_here

# ─── IBM Classical (Cloud Functions) ─────────────────────────────────────────

# IBM_CLOUD_API_KEY=your_ibm_cloud_api_key
# IBM_CF_API_HOST=us-south.functions.cloud.ibm.com
# IBM_CF_NAMESPACE=_

# ─── AWS ─────────────────────────────────────────────────────────────────────

# AWS_ACCESS_KEY_ID=your_aws_access_key_id
# AWS_SECRET_ACCESS_KEY=your_aws_secret_access_key
# AWS_REGION=us-east-1

# ─── Azure ───────────────────────────────────────────────────────────────────

# AZURE_TENANT_ID=your_azure_tenant_id
# AZURE_CLIENT_ID=your_azure_client_id
# AZURE_CLIENT_SECRET=your_azure_client_secret
# AZURE_LOCATION=westus

# ─── Google Cloud ───────────────────────────────────────────────────────────

# GOOGLE_PROJECT_ID=your_gcp_project_id
# PUBSUB_TOPIC_NAME=hal-job-updates

# ─── Redis (Optional) ───────────────────────────────────────────────────────

# REDIS_URL=redis://localhost:6379/0

# ─── Device & Execution Settings ────────────────────────────────────────────

# DEVICE_QUEUE_THRESHOLD=50
# PYTHON_EXEC_TIMEOUT=30
# SANDBOX_ALLOWED_MODULES=qiskit,numpy,math
